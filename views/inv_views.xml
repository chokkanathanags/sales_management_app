<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gold_category_tree" model="ir.ui.view">
        <field name="name">gold.category.tree</field>
        <field name="model">gold.category</field>
        <field name="arch" type="xml">
            <tree string="Jewelry Categories" editable="bottom">
                <field name="name" placeholder="e.g. Rings"/>
                <field name="description" placeholder="Short description..."/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_category_form" model="ir.ui.view">
        <field name="name">gold.category.form</field>
        <field name="model">gold.category</field>
        <field name="arch" type="xml">
            <form string="Jewelry Category">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="Category Name"/>
                        <h1><field name="name" placeholder="e.g. Diamond Rings &amp; Bangles"/></h1>
                    </div>
                    <notebook>
                        <page string="Category Details" name="details">
                            <group>
                                <field name="active" widget="boolean_toggle"/>
                                <field name="description" placeholder="Describe what items fall into this category..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gold_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">gold.category</field>
        <field name="view_mode">tree,form</field>
        <field name="limit">20</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first jewelry category!
            </p>
        </field>
    </record>

    <record id="view_gold_inventory_tree" model="ir.ui.view">
        <field name="name">gold.inventory.tree</field>
        <field name="model">gold.inventory</field>
        <field name="arch" type="xml">
            <tree string="Inventory Items" decoration-danger="state == 'damaged'" decoration-warning="state == 'quality_check'">
                <field name="name"/>
                <field name="sku"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="type"/>
                <field name="karat"/>
                <field name="quantity"/>
                <field name="qty_available"/>
                <field name="qty_reserved"/>
                <field name="store_location"/>
                <field name="state" widget="badge" decoration-success="state == 'available'" decoration-warning="state == 'quality_check'" decoration-danger="state == 'damaged'"/>
                <field name="total_value"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_inventory_form" model="ir.ui.view">
        <field name="name">gold.inventory.form</field>
        <field name="model">gold.inventory</field>
        <field name="arch" type="xml">
            <form string="Inventory Item" class="tab-inventory-accent">
                <header>
                    <button name="action_available" string="Make Available" type="object" class="btn-primary" invisible="state not in ['draft', 'quality_check']"/>
                    <button name="action_reserve" string="Reserve" type="object" class="btn-info" invisible="state != 'available'"/>
                    <button name="action_sell" string="Mark as Sold" type="object" class="btn-success" invisible="state != 'reserved'"/>
                    <button name="action_quality_check" string="Submit for QC" type="object" class="btn-warning" invisible="state not in ['available', 'draft']"/>
                    <button name="action_approve_qc" string="Approve (Pass QC)" type="object" class="btn-success" invisible="state != 'quality_check'"/>
                    <button name="action_reject_qc" string="Reject (Fail QC)" type="object" class="btn-danger" invisible="state != 'quality_check'"/>
                    <button name="action_mark_damaged" string="Mark Damaged" type="object" class="btn-danger" invisible="state in ['damaged', 'sold']"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state not in ['inactive', 'damaged']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,available,reserved,sold"/>
                </header>
                <sheet>

                    <field name="image" widget="image" class="oe_avatar" options='{"preview_image": "image"}'/>
                    <div class="oe_title">
                        <label for="name" string="Item Reference"/>
                        <h1><field name="name" placeholder="e.g. Necklace-001"/></h1>
                        <label for="sku" string="SKU Code"/>
                        <h2><field name="sku" placeholder="e.g. RING-GOLD-22K-001"/></h2>
                    </div>
                    <group>
                        <group string="Basic Information">
                            <field name="category_id" options="{'no_create': False, 'no_open': False}"/>
                            <field name="type"/>
                            <field name="collection" placeholder="e.g. Royal Heritage"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Tracking &amp; Logistics">
                            <field name="serial_number" placeholder="Unique Serial #"/>
                            <field name="barcode" placeholder="EAN/UPC Barcode"/>
                            <field name="lot_number" placeholder="Batch/Lot Number"/>
                            <field name="warehouse" placeholder="Main Warehouse"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Gold &amp; Physical Specs" name="specs">
                            <group>
                                <group string="Material Details">
                                    <field name="karat"/>
                                    <field name="purity" placeholder="Gold purity %"/>
                                    <field name="manufacture_date"/>
                                </group>
                                <group string="Weight Specs (g)">
                                    <field name="gross_weight"/>
                                    <field name="net_weight"/>
                                    <field name="stone_weight"/>
                                </group>
                            </group>
                        </page>
                        <page string="Stock &amp; Location" name="stock">
                            <group>
                                <group string="Quantities">
                                    <field name="quantity" class="oe_inline"/>
                                    <field name="qty_available" class="oe_inline" readonly="1"/>
                                    <field name="qty_reserved" class="oe_inline"/>
                                    <field name="qty_damaged" class="oe_inline"/>
                                </group>
                                <group string="Placement">
                                    <field name="store_location" placeholder="Store Name"/>
                                    <field name="bin_location" placeholder="Shelf/Bin ID"/>
                                    <field name="is_consignment"/>
                                    <field name="consignment_partner" invisible="not is_consignment"/>
                                </group>
                            </group>
                        </page>
                        <page string="Financials" name="financials">
                            <group>
                                <group string="Costing &amp; Rates">
                                    <field name="rate_id"/>
                                    <label for="making_charge" string="Making Charge"/>
                                    <div class="o_row">
                                        <field name="making_charge"/> (Fixed) + 
                                        <field name="making_charge_pct"/> %
                                    </div>
                                    <field name="wastage"/>
                                    <field name="stone_cost"/>
                                </group>
                                <group string="Taxation (%)">
                                    <field name="gst_gold"/>
                                    <field name="gst_making"/>
                                    <field name="gst_diamond"/>
                                </group>
                            </group>
                            <group>
                                <group string="Valuation Summary">
                                    <field name="base_value" widget="monetary" options="{'currency_field': 'currency_name'}" readonly="1"/>
                                    <field name="tax_amount" widget="monetary" readonly="1"/>
                                    <field name="total_value" widget="monetary" class="oe_read_only" readonly="1" decoration-bf="1"/>
                                    <field name="currency_name" invisible="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes &amp; Descriptions" name="notes">
                            <group>
                                <field name="description" placeholder="Public description..."/>
                                <field name="notes" placeholder="Internal staff notes..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gold_inventory_kanban" model="ir.ui.view">
        <field name="name">gold.inventory.kanban</field>
        <field name="model">gold.inventory</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="sku"/>
                <field name="quantity"/>
                <field name="image"/>
                <field name="karat"/>
                <field name="state"/>
                <field name="total_value"/>
                <field name="currency_name"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_image">
                                <field name="image" widget="image" options="{'zoom': true, 'background': true, 'prevent_create': true}"/>
                            </div>
                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    </div>
                                    <div class="o_dropdown_kanban dropdown">
                                        <a class="dropdown-toggle o-no-caret btn btn-xs" data-toggle="dropdown" href="#" role="button">
                                            <i class="fa fa-ellipsis-v" aria-label="Selection" title="Selection"/>
                                        </a>
                                        <div class="dropdown-menu" role="menu">
                                            <t t-if="widget.editable"><a role="menuitem" type="edit" class="dropdown-item">Edit</a></t>
                                            <t t-if="widget.deletable"><a role="menuitem" type="delete" class="dropdown-item">Delete</a></t>
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_record_subtitle">
                                    <field name="sku"/>
                                </div>
                                <div>
                                    <span class="badge badge-pill badge-primary"><field name="karat"/></span>
                                    <span class="badge badge-pill badge-info"><field name="category_id"/></span>
                                </div>
                                <div class="mt-2 text-primary font-weight-bold">
                                    <field name="total_value" widget="monetary" options="{'currency_field': 'currency_name'}"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        Qty: <field name="quantity"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'available': 'success', 'reserved': 'info', 'sold': 'warning', 'damaged': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_gold_inventory_search" model="ir.ui.view">
        <field name="name">gold.inventory.search</field>
        <field name="model">gold.inventory</field>
        <field name="arch" type="xml">
            <search string="Search Inventory">
                <field name="name" string="Item/SKU" filter_domain="['|', ('name', 'ilike', self), ('sku', 'ilike', self)]"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="karat"/>
                <field name="state"/>
                <field name="store_location"/>
                
                <separator/>
                <filter name="available" string="Available Stock" domain="[('state', '=', 'available')]"/>
                <filter name="low_stock" string="Low Stock Alerts" domain="[('qty_available', '&lt;=', 'low_stock_threshold')]"/>
                <filter name="consignment" string="Consignment Items" domain="[('is_consignment', '=', True)]"/>
                
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_category" string="Category" context="{'group_by': 'category_id'}"/>
                    <filter name="group_by_type" string="Jewelry Type" context="{'group_by': 'type'}"/>
                    <filter name="group_by_karat" string="Karat/Purity" context="{'group_by': 'karat'}"/>
                    <filter name="group_by_location" string="Location" context="{'group_by': 'store_location'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_gold_inventory_transfer_tree" model="ir.ui.view">
        <field name="name">gold.inventory.transfer.tree</field>
        <field name="model">gold.inventory.transfer</field>
        <field name="arch" type="xml">
            <tree string="Transfers" decoration-info="state == 'in_transit'" decoration-success="state == 'done'">
                <field name="name"/>
                <field name="inventory_id"/>
                <field name="from_location"/>
                <field name="to_location"/>
                <field name="quantity"/>
                <field name="logistics_id" string="Shipment status" widget="badge" 
                       decoration-info="logistics_id != False" 
                       decoration-success="state == 'done'"
                       decoration-muted="not logistics_id"/>
                <field name="state" widget="badge"/>
                <field name="transfer_date"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_inventory_transfer_form" model="ir.ui.view">
        <field name="name">gold.inventory.transfer.form</field>
        <field name="model">gold.inventory.transfer</field>
        <field name="arch" type="xml">
            <form string="Stock Transfer">
                <header>
                    <button name="action_approve" string="1. Approve Transfer" type="object" class="btn-primary" invisible="state != 'draft'" help="Verifies item availability and locks the transfer details."/>
                    <button name="action_transit" string="2. Dispatch Shipment" type="object" class="btn-primary" invisible="state != 'approved'" help="Moves items from stock to 'In Transit' bucket and creates tracking."/>
                    <button name="action_done" string="3. Receive Items" type="object" class="btn-success" invisible="state != 'in_transit'" help="Finalizes the transfer and updates the new location's stock."/>
                    <button name="action_cancel" string="Cancel Transfer" type="object" class="btn-secondary" invisible="state in ['done', 'cancelled']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,in_transit,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logistics" type="object" class="oe_stat_button" icon="fa-truck" invisible="logistics_id == False">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Shipment</span>
                            </div>
                        </button>
                    </div>
                    <field name="logistics_id" invisible="1"/>
                    <div class="oe_title">
                        <label for="name" string="Transfer Reference"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Transfer Details">
                            <field name="inventory_id"/>
                            <field name="quantity"/>
                        </group>
                        <group string="Locations &amp; Dates">
                            <field name="from_location" help="Current location of the jewelry item."/>
                            <field name="to_location" help="Target destination for this transfer."/>
                            <field name="transfer_date" readonly="1" help="Date when the items left the source location."/>
                            <field name="estimated_arrival" help="When the items are expected to reach the destination."/>
                            <field name="actual_arrival" readonly="1" help="System recorded time of receipt."/>
                        </group>
                    </group>
                    <group>
                        <group string="Personnel">
                            <field name="approved_by" readonly="1"/>
                            <field name="cost"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gold_inventory_transfer_search" model="ir.ui.view">
        <field name="name">gold.inventory.transfer.search</field>
        <field name="model">gold.inventory.transfer</field>
        <field name="arch" type="xml">
            <search string="Search Transfers">
                <field name="name"/>
                <field name="from_location"/>
                <field name="to_location"/>
                <field name="state"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gold_inventory" model="ir.actions.act_window">
        <field name="name">Inventory</field>
        <field name="res_model">gold.inventory</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="limit">20</field>
    </record>

    <record id="action_gold_inventory_transfer" model="ir.actions.act_window">
        <field name="name">Stock Transfers</field>
        <field name="res_model">gold.inventory.transfer</field>
        <field name="view_mode">tree,form</field>
        <field name="limit">20</field>
    </record>

    <menuitem id="menu_gold_inventory" name="Jewelry Items" parent="menu_gold_inventory_root" action="action_gold_inventory" sequence="10"/>
    <menuitem id="menu_gold_category" name="Categories" parent="menu_gold_inventory_root" action="action_gold_category" sequence="15"/>
    <menuitem id="menu_gold_inventory_transfer" name="Stock Transfers" parent="menu_gold_inventory_root" action="action_gold_inventory_transfer" sequence="20"/>
</odoo>
