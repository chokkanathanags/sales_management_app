<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gold_category_tree" model="ir.ui.view">
        <field name="name">gold.category.tree</field>
        <field name="model">gold.category</field>
        <field name="arch" type="xml">
            <tree string="Jewelry Categories" editable="bottom">
                <field name="name" placeholder="e.g. Rings"/>
                <field name="description" placeholder="Short description..."/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_category_form" model="ir.ui.view">
        <field name="name">gold.category.form</field>
        <field name="model">gold.category</field>
        <field name="arch" type="xml">
            <form string="Jewelry Category">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="Category Name"/>
                        <h1><field name="name" placeholder="e.g. Diamond Rings &amp; Bangles"/></h1>
                    </div>
                    <notebook>
                        <page string="Category Details" name="details">
                            <group>
                                <field name="active" widget="boolean_toggle"/>
                                <field name="description" placeholder="Describe what items fall into this category..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gold_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">gold.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first jewelry category!
            </p>
        </field>
    </record>

    <record id="view_gold_inventory_tree" model="ir.ui.view">
        <field name="name">gold.inventory.tree</field>
        <field name="model">gold.inventory</field>
        <field name="arch" type="xml">
            <tree string="Inventory Items" decoration-danger="state == 'damaged'" decoration-warning="state == 'quality_check'">
                <field name="name"/>
                <field name="sku"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="type"/>
                <field name="karat"/>
                <field name="quantity"/>
                <field name="qty_available"/>
                <field name="qty_reserved"/>
                <field name="store_location"/>
                <field name="state" widget="badge" decoration-success="state == 'available'" decoration-warning="state == 'quality_check'" decoration-danger="state == 'damaged'"/>
                <field name="total_value"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_inventory_form" model="ir.ui.view">
        <field name="name">gold.inventory.form</field>
        <field name="model">gold.inventory</field>
        <field name="arch" type="xml">
            <form string="Inventory Item" class="tab-inventory-accent">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="available,reserved,in_transit,quality_check,damaged"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options='{"preview_image": "image"}'/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="Item Reference"/>
                        <h1><field name="name" placeholder="e.g. 22K Gold Wedding Bangle"/></h1>
                        <label for="sku" string="SKU Code"/>
                        <h2><field name="sku" placeholder="e.g. RING-001-GOLD"/></h2>
                        <label for="serial_number" string="Unique Serial"/>
                        <h3><field name="serial_number" placeholder="e.g. SN-987654321"/></h3>
                    </div>
                    
                    <notebook>
                        <page string="General Information" name="info">
                            <group>
                                <group string="Classification">
                                    <field name="category_id" placeholder="e.g. Rings, Necklaces, Bangles" options="{'no_create': True}"/>
                                    <field name="collection" placeholder="e.g. Bridal Collection 2024"/>
                                    <field name="type"/>
                                    <field name="karat"/>
                                    <field name="purity" placeholder="e.g. 91.60"/>
                                </group>
                                <group string="Physical Specs">
                                    <field name="gross_weight" placeholder="e.g. 10.500"/>
                                    <field name="net_weight" placeholder="e.g. 10.250"/>
                                    <field name="stone_weight" placeholder="e.g. 0.250"/>
                                    <field name="manufacture_date" placeholder="Select Date"/>
                                </group>
                            </group>
                            <group string="Tracking">
                                <group>
                                    <field name="barcode" placeholder="Scan or enter item barcode"/>
                                    <field name="rfid_tag" placeholder="Enter RFID Tag ID if applicable"/>
                                </group>
                                <group>
                                    <field name="lot_number" placeholder="Enter Batch/Lot Number"/>
                                    <field name="active"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Inventory &amp; Storage" name="inventory">
                            <group>
                                <group string="Current Stock">
                                    <field name="quantity" class="oe_inline"/>
                                    <field name="qty_available" class="oe_inline"/>
                                    <field name="qty_reserved" class="oe_inline"/>
                                </group>
                                <group string="Storage Location">
                                    <field name="warehouse" placeholder="e.g. Central Vault"/>
                                    <field name="store_location" placeholder="e.g. Display Case 4"/>
                                    <field name="bin_location" placeholder="e.g. Slot B-12"/>
                                </group>
                            </group>
                            <group string="Operational Quantities">
                                <group>
                                    <field name="qty_in_transit"/>
                                    <field name="qty_in_production"/>
                                </group>
                                <group>
                                    <field name="qty_on_order"/>
                                    <field name="qty_damaged"/>
                                </group>
                            </group>
                            <group string="Risk Management">
                                <field name="safety_stock"/>
                                <field name="low_stock_threshold"/>
                            </group>
                            <group string="Consignment" invisible="not is_consignment">
                                <field name="is_consignment"/>
                                <field name="consignment_partner" placeholder="Enter Partner/Broker Name"/>
                            </group>
                        </page>
                        
                        <page string="Pricing &amp; Value" name="pricing">
                            <group>
                                <group string="Input Rates">
                                    <field name="rate_id" placeholder="Select Today's Gold Rate"/>
                                    <field name="making_charge" placeholder="e.g. 500.00 (Fixed/Per Gram)"/>
                                    <field name="stone_cost" placeholder="e.g. 1500.00 (Total Stone Value)"/>
                                    <field name="wastage" placeholder="e.g. 5.0 (%)"/>
                                </group>
                                <group string="Automated Value (INR)">
                                    <field name="base_value" decoration-info="1" widget="monetary"/>
                                    <field name="tax_amount" decoration-muted="1" widget="monetary"/>
                                    <field name="total_value" decoration-bf="1" widget="monetary" class="text-primary"/>
                                    <field name="currency_name" invisible="1"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Internal Notes" name="notes">
                            <field name="description" placeholder="Add a detailed customer-facing description..."/>
                            <field name="notes" placeholder="For internal store use only..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gold_inventory_kanban" model="ir.ui.view">
        <field name="name">gold.inventory.kanban</field>
        <field name="model">gold.inventory</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="sku"/>
                <field name="quantity"/>
                <field name="image"/>
                <field name="karat"/>
                <field name="state"/>
                <field name="total_value"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <field name="image" widget="image" class="oe_avatar"/>
                            </div>
                            <div class="o_kanban_record_top">
                                <strong><field name="name"/></strong>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><field name="sku"/></div>
                                <div>Karat: <field name="karat"/></div>
                                <div>Qty: <field name="quantity"/></div>
                                <div>Status: <field name="state"/></div>
                                <div>Value: <field name="total_value"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_gold_inventory_search" model="ir.ui.view">
        <field name="name">gold.inventory.search</field>
        <field name="model">gold.inventory</field>
        <field name="arch" type="xml">
            <search string="Search Inventory">
                <field name="name"/>
                <field name="sku"/>
                <field name="serial_number"/>
                <field name="barcode"/>
                <field name="rfid_tag"/>
                <field name="category_id"/>
                <field name="karat"/>
                <field name="state"/>
                <field name="store_location"/>
                <field name="warehouse"/>
                <filter name="available" string="Available" domain="[('state', '=', 'available')]"/>
                <filter name="low_stock" string="Low Stock" domain="[('qty_available', '&lt;=', 'low_stock_threshold')]"/>
                <filter name="damaged" string="Damaged" domain="[('state', '=', 'damaged')]"/>
                <filter name="quality_check" string="QC Pending" domain="[('state', '=', 'quality_check')]"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_category" string="Category" context="{'group_by': 'category_id'}"/>
                    <filter name="group_by_karat" string="Karat" context="{'group_by': 'karat'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_warehouse" string="Warehouse" context="{'group_by': 'warehouse'}"/>
                    <filter name="group_by_type" string="Type" context="{'group_by': 'type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_gold_inventory_transfer_tree" model="ir.ui.view">
        <field name="name">gold.inventory.transfer.tree</field>
        <field name="model">gold.inventory.transfer</field>
        <field name="arch" type="xml">
            <tree string="Transfers" decoration-info="state == 'in_transit'" decoration-success="state == 'done'">
                <field name="name"/>
                <field name="inventory_id"/>
                <field name="from_location"/>
                <field name="to_location"/>
                <field name="quantity"/>
                <field name="state" widget="badge"/>
                <field name="transfer_date"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_inventory_transfer_form" model="ir.ui.view">
        <field name="name">gold.inventory.transfer.form</field>
        <field name="model">gold.inventory.transfer</field>
        <field name="arch" type="xml">
            <form string="Stock Transfer">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,in_transit,done"/>
                </header>
                <sheet>
                    <group>
                        <group string="Transfer Details">
                            <field name="name"/>
                            <field name="inventory_id"/>
                            <field name="quantity"/>
                        </group>
                        <group string="Locations">
                            <field name="from_location"/>
                            <field name="to_location"/>
                            <field name="transfer_date"/>
                            <field name="estimated_arrival"/>
                        </group>
                    </group>
                    <group>
                        <group string="Approval">
                            <field name="approved_by"/>
                            <field name="cost"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gold_inventory_transfer_search" model="ir.ui.view">
        <field name="name">gold.inventory.transfer.search</field>
        <field name="model">gold.inventory.transfer</field>
        <field name="arch" type="xml">
            <search string="Search Transfers">
                <field name="name"/>
                <field name="from_location"/>
                <field name="to_location"/>
                <field name="state"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gold_inventory" model="ir.actions.act_window">
        <field name="name">Inventory</field>
        <field name="res_model">gold.inventory</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <record id="action_gold_inventory_transfer" model="ir.actions.act_window">
        <field name="name">Stock Transfers</field>
        <field name="res_model">gold.inventory.transfer</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
