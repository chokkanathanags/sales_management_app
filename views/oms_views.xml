<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gold_purchase_tree" model="ir.ui.view">
        <field name="name">gold.purchase.tree</field>
        <field name="model">gold.purchase</field>
        <field name="arch" type="xml">
            <tree string="Orders" 
                  decoration-info="state == 'draft'"
                  decoration-warning="state in ('confirmed', 'quality_check', 'packed')" 
                  decoration-primary="state == 'dispatched'"
                  decoration-success="state == 'delivered'" 
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="order_date"/>
                <field name="customer_id"/>
                <field name="total_value" widget="monetary" options="{'currency_field': 'currency_name'}" sum="Total Orders"/>
                <field name="currency_name" invisible="1"/>
                <field name="payment_status" widget="badge" 
                       decoration-success="payment_status == 'paid'" 
                       decoration-warning="payment_status == 'partial'"
                       decoration-danger="payment_status == 'failed'"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('confirmed', 'quality_check', 'packed')" 
                       decoration-primary="state == 'dispatched'"
                       decoration-success="state == 'delivered'" 
                       decoration-muted="state == 'cancelled'"/>
                <field name="order_source"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_purchase_form" model="ir.ui.view">
        <field name="name">gold.purchase.form</field>
        <field name="model">gold.purchase</field>
        <field name="arch" type="xml">
            <form string="Order">
                <header>
                    <button name="action_confirm" string="Confirm Order" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_quality_check" string="Quality Check" type="object" class="btn-info" invisible="state != 'confirmed'"/>
                    <button name="action_packed" string="Mark Packed" type="object" class="btn-info" invisible="state != 'quality_check'"/>
                    <button name="action_dispatch" string="Dispatch" type="object" class="btn-primary" invisible="state != 'packed'"/>
                    <button name="action_delivered" string="Mark Delivered" type="object" class="btn-success" invisible="state != 'dispatched'"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-danger" invisible="state in ('delivered', 'cancelled')"/>
                    <button name="action_set_to_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,quality_check,packed,dispatched,delivered"/>
                </header>
                <sheet>

                    <div class="oe_title">
                        <label for="name" string="Order Number"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group readonly="state == 'delivered' and payment_status == 'paid'">
                        <group string="Order Identity">
                            <field name="partner_id" widget="res_partner_many2one" context="{'res_partner_search_mode': 'customer'}" options="{'no_create': True}"/>
                            <field name="customer_id" options="{'no_create': True}"/>
                            <field name="order_date"/>
                            <field name="order_type"/>
                            <field name="order_source" widget="radio" options="{'horizontal': True}"/>
                        </group>
                        <group string="Financials &amp; Fulfillment">
                            <field name="payment_method" widget="radio" options="{'horizontal': True}"/>
                            <field name="payment_status" widget="badge" decoration-success="payment_status == 'paid'" decoration-danger="payment_status == 'unpaid'" decoration-warning="payment_status == 'partial'"/>
                            <field name="fulfillment_model"/>
                            <field name="fulfillment_store" placeholder="e.g. Main Store"/>
                            <field name="expected_delivery_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines">
                            <field name="order_line_ids">
                                <tree editable="bottom" limit="10">
                                    <field name="inventory_id"/>
                                    <field name="rate_id" column_invisible="True"/>
                                    <field name="stone_cost" column_invisible="True"/>
                                    <field name="discount_amount" column_invisible="True"/>
                                    <field name="gross_weight" column_invisible="True"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="karat"/>
                                    <field name="net_weight"/>
                                    <field name="base_value"/>
                                    <field name="making_charge"/>
                                    <field name="tax_amount"/>
                                    <field name="line_total" sum="Total"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <label for="available_coupon_id" string="Promo Code"/>
                                <div class="o_row">
                                    <field name="available_coupon_id" placeholder="Select a code..." invisible="state != 'draft'"/>
                                    <field name="coupon_code" placeholder="Manual entry..." invisible="available_coupon_id"/>
                                    <button name="action_apply_coupon" type="object" string="Apply" class="btn-link" invisible="state != 'draft' or available_coupon_id"/>
                                </div>
                                <field name="promotion_id" readonly="1" invisible="not promotion_id"/>
                                <field name="subtotal" string="Untaxed Subtotal" widget="monetary" readonly="1"/>
                                <field name="tax_amount" string="Total GST (3%)" widget="monetary" readonly="1"/>
                                <field name="discount_amount" string="Promotional Discount" widget="monetary" decoration-danger="discount_amount > 0" invisible="discount_amount == 0"/>
                                <field name="loyalty_points_used" string="Loyalty Redemption" widget="monetary" invisible="loyalty_points_used == 0"/>
                                <div class="oe_subtotal_footer_separator oe_inline">
                                    <label for="total_value"/>
                                </div>
                                <field name="total_value" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary" readonly="1"/>
                            </group>
                        </page>
                        <page string="Shipping &amp; Delivery">
                            <group>
                                <group string="Delivery Locations">
                                    <field name="shipping_address" placeholder="Full shipping address"/>
                                    <field name="billing_address" placeholder="Full billing address"/>
                                    <field name="pincode" placeholder="e.g. 560001"/>
                                </group>
                                <group string="Delivery Options">
                                    <field name="delivery_slot"/>
                                    <field name="is_gift"/>
                                    <field name="gift_message" invisible="is_gift == False"/>
                                    <field name="gift_wrapping" invisible="is_gift == False"/>
                                </group>
                            </group>
                        </page>
                        <page string="Customization" invisible="order_type not in ['customization', 'made_to_order']">
                            <group>
                                <field name="customization_notes"/>
                                <field name="engraving_text"/>
                                <field name="resize_spec"/>
                            </group>
                        </page>
                        <page string="Payment &amp; Loyalty">
                            <group>
                                <group string="Payment">
                                    <field name="payment_method"/>
                                    <field name="payment_transaction_id"/>
                                    <field name="advance_amount"/>
                                </group>
                                <group string="Loyalty Hub">
                                    <field name="loyalty_points_earned" readonly="1"/>
                                    <field name="loyalty_points_used" readonly="1"/>
                                    <button name="action_redeem_loyalty" string="Redeem Available Points" 
                                            type="object" class="btn-secondary" 
                                            invisible="state != 'draft' or loyalty_points_used > 0"
                                            help="Click to apply available loyalty points as a discount"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gold_purchase_kanban" model="ir.ui.view">
        <field name="name">gold.purchase.kanban</field>
        <field name="model">gold.purchase</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="total_value"/>
                <field name="state"/>
                <field name="currency_name"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong><field name="name"/></strong>
                                <span class="float-right badge badge-info"><field name="state"/></span>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><field name="customer_id"/></div>
                                <div>Value: <field name="total_value" widget="monetary" options="{'currency_field': 'currency_name'}"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_gold_purchase_search" model="ir.ui.view">
        <field name="name">gold.purchase.search</field>
        <field name="model">gold.purchase</field>
        <field name="arch" type="xml">
            <search string="Search Orders">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="order_type"/>
                <field name="state"/>
                <field name="payment_status"/>
                <filter name="confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="delivered" string="Delivered" domain="[('state', '=', 'delivered')]"/>
                <filter name="bopis" string="BOPIS" domain="[('order_type', '=', 'bopis')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_customer" string="Customer" context="{'group_by': 'customer_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_type" string="Order Type" context="{'group_by': 'order_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gold_purchase" model="ir.actions.act_window">
        <field name="name">Orders (OMS)</field>
        <field name="res_model">gold.purchase</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="limit">20</field>
    </record>

    <menuitem id="menu_gold_oms_root" name="Order Management" parent="menu_sales_management_root" sequence="40"/>
    <menuitem id="menu_gold_purchase" name="All Orders" parent="menu_gold_oms_root" action="action_gold_purchase" sequence="10"/>
</odoo>
