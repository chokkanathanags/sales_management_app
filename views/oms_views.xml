<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gold_purchase_tree" model="ir.ui.view">
        <field name="name">gold.purchase.tree</field>
        <field name="model">gold.purchase</field>
        <field name="arch" type="xml">
            <tree string="Orders" decoration-info="state in ('confirmed', 'payment_received')" decoration-success="state == 'delivered'" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="order_date"/>
                <field name="customer_id"/>
                <field name="order_type"/>
                <field name="total_value"/>
                <field name="payment_status" widget="badge" decoration-success="payment_status == 'paid'" decoration-warning="payment_status == 'partial'"/>
                <field name="state" widget="badge" decoration-success="state == 'delivered'" decoration-info="state == 'confirmed'" decoration-muted="state == 'cancelled'"/>
                <field name="order_source"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_purchase_form" model="ir.ui.view">
        <field name="name">gold.purchase.form</field>
        <field name="model">gold.purchase</field>
        <field name="arch" type="xml">
            <form string="Order">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,payment_received,dispatched,delivered"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Order Number"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Order Info">
                            <field name="partner_id"/>
                            <field name="customer_id"/>
                            <field name="order_date"/>
                            <field name="order_type"/>
                            <field name="order_source"/>
                        </group>
                        <group string="Fulfillment">
                            <field name="fulfillment_model"/>
                            <field name="fulfillment_store"/>
                            <field name="expected_delivery_date"/>
                            <field name="payment_status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines">
                            <field name="order_line_ids">
                                <tree editable="bottom">
                                    <field name="inventory_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="karat"/>
                                    <field name="net_weight"/>
                                    <field name="base_value"/>
                                    <field name="making_charge"/>
                                    <field name="tax_amount"/>
                                    <field name="line_total" sum="Total"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="subtotal" widget="monetary"/>
                                <field name="making_charge" widget="monetary"/>
                                <field name="tax_amount" widget="monetary"/>
                                <field name="discount_amount" widget="monetary"/>
                                <div class="oe_subtotal_footer_separator oe_inline">
                                    <label for="total_value"/>
                                </div>
                                <field name="total_value" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary"/>
                            </group>
                        </page>
                        <page string="Shipping &amp; Delivery">
                            <group>
                                <group string="Addresses">
                                    <field name="shipping_address"/>
                                    <field name="billing_address"/>
                                    <field name="pincode"/>
                                </group>
                                <group string="Delivery Options">
                                    <field name="delivery_slot"/>
                                    <field name="is_gift"/>
                                    <field name="gift_message" invisible="is_gift == False"/>
                                    <field name="gift_wrapping" invisible="is_gift == False"/>
                                </group>
                            </group>
                        </page>
                        <page string="Customization" invisible="order_type not in ['customization', 'made_to_order']">
                            <group>
                                <field name="customization_notes"/>
                                <field name="engraving_text"/>
                                <field name="resize_spec"/>
                            </group>
                        </page>
                        <page string="Payment &amp; Loyalty">
                            <group>
                                <group string="Payment">
                                    <field name="payment_method"/>
                                    <field name="payment_transaction_id"/>
                                    <field name="advance_amount"/>
                                </group>
                                <group string="Loyalty">
                                    <field name="loyalty_points_earned"/>
                                    <field name="loyalty_points_used"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gold_purchase_kanban" model="ir.ui.view">
        <field name="name">gold.purchase.kanban</field>
        <field name="model">gold.purchase</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="total_value"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong><field name="name"/></strong>
                                <span class="float-right badge badge-info"><field name="state"/></span>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><field name="customer_id"/></div>
                                <div>Value: <field name="total_value"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_gold_purchase_search" model="ir.ui.view">
        <field name="name">gold.purchase.search</field>
        <field name="model">gold.purchase</field>
        <field name="arch" type="xml">
            <search string="Search Orders">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="order_type"/>
                <field name="state"/>
                <field name="payment_status"/>
                <filter name="confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="delivered" string="Delivered" domain="[('state', '=', 'delivered')]"/>
                <filter name="bopis" string="BOPIS" domain="[('order_type', '=', 'bopis')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_customer" string="Customer" context="{'group_by': 'customer_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_type" string="Order Type" context="{'group_by': 'order_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gold_purchase" model="ir.actions.act_window">
        <field name="name">Orders (OMS)</field>
        <field name="res_model">gold.purchase</field>
        <field name="view_mode">tree,kanban,form</field>
    </record>

    <menuitem id="menu_gold_oms_root" name="Order Management" parent="menu_sales_management_root" sequence="40"/>
    <menuitem id="menu_gold_purchase" name="All Orders" parent="menu_gold_oms_root" action="action_gold_purchase" sequence="10"/>
</odoo>
