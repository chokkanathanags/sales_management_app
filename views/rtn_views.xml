<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gold_returns_tree" model="ir.ui.view">
        <field name="name">gold.returns.tree</field>
        <field name="model">gold.returns</field>
        <field name="arch" type="xml">
            <tree string="Returns" 
                  decoration-info="state == 'submitted'" 
                  decoration-warning="state in ('approved', 'received', 'qc_passed', 'refund_initiated')" 
                  decoration-success="state == 'completed'" 
                  decoration-danger="state in ('qc_failed', 'cancelled', 'rejected')">
                <field name="name"/>
                <field name="order_id"/>
                <field name="customer_id"/>
                <field name="return_type"/>
                <field name="initiation_date" widget="date"/>
                <field name="sla_deadline" widget="remaining_days"/>
                <field name="final_refund_amount" widget="monetary" options="{'currency_field': 'currency_name'}" sum="Total Refunds"/>
                <field name="currency_name" invisible="1"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'submitted'" 
                       decoration-warning="state in ('approved', 'received', 'qc_passed')" 
                       decoration-success="state == 'completed'" 
                       decoration-danger="state == 'qc_failed'"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_returns_form" model="ir.ui.view">
        <field name="name">gold.returns.form</field>
        <field name="model">gold.returns</field>
        <field name="arch" type="xml">
            <form string="Return Request">
                <header>
                    <button name="action_submit" string="Submit Request" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve Return" type="object" class="btn-success" invisible="state != 'submitted'"/>
                    <button name="action_receive" string="Confirm Receipt" type="object" class="btn-info" invisible="state != 'approved'"/>
                    <button name="action_qc_pass" string="QC Pass" type="object" class="btn-success" invisible="state != 'received'"/>
                    <button name="action_qc_fail" string="QC Fail" type="object" class="btn-danger" invisible="state != 'received'"/>
                    <button name="action_initiate_refund" string="Initiate Refund" type="object" class="btn-primary" invisible="state != 'qc_passed'"/>
                    <button name="action_complete" string="Complete Return" type="object" class="btn-success" invisible="state != 'refund_initiated'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ['completed', 'cancelled']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,received,qc_passed,completed"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Completed" bg_color="text-bg-success" invisible="state != 'completed'"/>
                    <widget name="web_ribbon" title="QC Failed" bg_color="text-bg-danger" invisible="state != 'qc_failed'"/>
                    <widget name="web_ribbon" title="Refunded" bg_color="text-bg-info" invisible="refund_state != 'processed'"/>

                    <div class="oe_title">
                        <label for="name" string="RMA Number / Return Ref"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Origin &amp; Type">
                            <field name="order_id" options="{'no_create': True}"/>
                            <field name="customer_id" options="{'no_create': True}"/>
                            <field name="return_type"/>
                            <field name="reason"/>
                        </group>
                        <group string="Timeline">
                            <field name="initiation_date"/>
                            <field name="sla_deadline"/>
                            <field name="approval_date" readonly="1"/>
                            <field name="completion_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Return Items &amp; Images" name="items">
                            <group>
                                <group string="Product Details">
                                    <field name="order_line_id" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="returned_item_sku" readonly="1" force_save="1"/>
                                    <field name="returned_item_name" readonly="1" force_save="1"/>
                                    <field name="original_qty"/>
                                    <field name="returned_quantity"/>
                                </group>
                                <group string="Visual Evidence">
                                    <field name="customer_images" widget="image" class="oe_avatar"/>
                                    <field name="reason_notes" placeholder="Customer comments..."/>
                                </group>
                            </group>
                            <separator string="Exchange Details" invisible="return_type not in ['exchange_same', 'exchange_different', 'old_gold']"/>
                            <group invisible="return_type not in ['exchange_same', 'exchange_different', 'old_gold']">
                                <group>
                                    <field name="exchange_item_sku"/>
                                    <field name="exchange_item_name"/>
                                </group>
                                <group string="Value Adjustments">
                                    <field name="exchange_price_diff"/>
                                    <field name="old_gold_value" invisible="return_type != 'old_gold'" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Inspection &amp; Logistics" name="inspection">
                            <group>
                                <group string="Quality Control">
                                    <field name="qc_status" widget="radio" options="{'horizontal': true}"/>
                                    <field name="qc_done_by"/>
                                    <field name="qc_notes" placeholder="Inspector's observations..."/>
                                </group>
                                <group string="Shipping Tracking">
                                    <field name="logistics_id"/>
                                    <field name="return_awb"/>
                                    <field name="return_pickup_date"/>
                                    <field name="return_received_date"/>
                                </group>
                            </group>
                        </page>
                        <page string="Refund &amp; Payback" name="refund" invisible="return_type == 'old_gold'">
                            <group>
                                <group string="Refund Strategy">
                                    <field name="refund_type"/>
                                    <field name="refund_state" widget="badge"/>
                                </group>
                                <group string="Settlement">
                                    <field name="final_refund_amount" widget="monetary" options="{'currency_field': 'currency_name'}" readonly="1"/>
                                    <field name="refund_date"/>
                                    <field name="refund_transaction_id"/>
                                    <field name="currency_name" invisible="1"/>
                                </group>
                            </group>
                            <group string="Deduction Breakdown">
                                <field name="refund_amount"/>
                                <field name="shipping_deduction"/>
                                <field name="restocking_deduction"/>
                            </group>
                        </page>
                        <page string="Original Order Items" name="order_items">
                            <field name="order_id" invisible="1"/>
                            <field name="order_line_ids_ref" invisible="1"/> <!-- Added a helper field in model next -->
                            <group string="Items from Original Order">
                                <field name="order_line_ids_ref" nolabel="1" readonly="1">
                                    <tree limit="10">
                                        <field name="sku"/>
                                        <field name="name"/>
                                        <field name="quantity" string="Qty Bought"/>
                                        <field name="base_value" widget="monetary"/>
                                        <field name="line_total" widget="monetary"/>
                                    </tree>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_gold_returns_kanban" model="ir.ui.view">
        <field name="name">gold.returns.kanban</field>
        <field name="model">gold.returns</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="state"/>
                <field name="initiation_date"/>
                <field name="final_refund_amount"/>
                <field name="return_type"/>
                <field name="currency_name"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <span class="float-end"><field name="initiation_date" widget="date"/></span>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="customer_id"/>
                                <div class="mt-1">
                                    <field name="state" widget="badge" decoration-success="state == 'completed'" decoration-info="state == 'approved'"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom mt-2">
                                <div class="oe_kanban_bottom_left">
                                    <field name="return_type" widget="badge"/>
                                </div>
                                <div class="oe_kanban_bottom_right fw-bold">
                                    <field name="final_refund_amount" widget="monetary" options="{'currency_field': 'currency_name'}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_gold_returns_graph" model="ir.ui.view">
        <field name="name">gold.returns.graph</field>
        <field name="model">gold.returns</field>
        <field name="arch" type="xml">
            <graph string="Returns Analysis" sample="1">
                <field name="reason"/>
                <field name="final_refund_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_gold_returns_pivot" model="ir.ui.view">
        <field name="name">gold.returns.pivot</field>
        <field name="model">gold.returns</field>
        <field name="arch" type="xml">
            <pivot string="Returns Analysis" sample="1">
                <field name="initiation_date" type="row"/>
                <field name="return_type" type="col"/>
                <field name="final_refund_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_gold_returns_calendar" model="ir.ui.view">
        <field name="name">gold.returns.calendar</field>
        <field name="model">gold.returns</field>
        <field name="arch" type="xml">
            <calendar string="Returns" date_start="initiation_date" color="state" mode="month">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_gold_returns_search" model="ir.ui.view">
        <field name="name">gold.returns.search</field>
        <field name="model">gold.returns</field>
        <field name="arch" type="xml">
            <search string="Search Returns">
                <field name="name" string="RMA/Order/Customer" filter_domain="['|', '|', ('name', 'ilike', self), ('order_id', 'ilike', self), ('customer_id', 'ilike', self)]"/>
                <field name="order_id"/>
                <field name="customer_id"/>
                <field name="state"/>
                <field name="qc_status"/>
                <separator/>
                <filter name="pending_qc" string="QC Pending" domain="[('qc_status', '=', 'pending')]"/>
                <filter name="qc_passed" string="QC Passed" domain="[('qc_status', '=', 'passed')]"/>
                <filter name="pending_refund" string="Refund To Process" domain="[('refund_state', '=', 'pending'), ('state', '=', 'approved')]"/>
                <separator/>
                <filter name="today" string="Initiated Today" domain="[('initiation_date', '&gt;=', datetime.datetime.now().strftime('%Y-%m-%d 00:00:00')), ('initiation_date', '&lt;=', datetime.datetime.now().strftime('%Y-%m-%d 23:59:59'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_customer" string="Customer" context="{'group_by': 'customer_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_type" string="Return Type" context="{'group_by': 'return_type'}"/>
                    <filter name="group_by_reason" string="Reason" context="{'group_by': 'reason'}"/>
                    <filter name="group_by_month" string="Initiation Month" context="{'group_by': 'initiation_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gold_returns" model="ir.actions.act_window">
        <field name="name">Returns &amp; Exchanges</field>
        <field name="res_model">gold.returns</field>
        <field name="view_mode">tree,kanban,calendar,graph,pivot,form</field>
        <field name="limit">20</field>
        <field name="context">{'search_default_pending_qc': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record your first return request!
            </p><p>
                Manage RMA, quality checks, exchanges, and financial refunds.
            </p>
        </field>
    </record>

    <menuitem id="menu_gold_rtn_root" name="Returns" parent="menu_sales_management_root" sequence="80"/>
    <menuitem id="menu_gold_returns" name="All Returns" parent="menu_gold_rtn_root" action="action_gold_returns" sequence="10"/>
</odoo>
