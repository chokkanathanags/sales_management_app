<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gold_logistics_tree" model="ir.ui.view">
        <field name="name">gold.logistics.tree</field>
        <field name="model">gold.logistics</field>
        <field name="arch" type="xml">
            <tree string="Shipments" create="0"
                  decoration-info="status == 'label_created'"
                  decoration-warning="status in ('pickup_scheduled', 'picked_up', 'in_transit')" 
                  decoration-success="status == 'delivered'" 
                  decoration-danger="status == 'delivery_failed'">
                <field name="name"/>
                <field name="order_id"/>
                <field name="carrier"/>
                <field name="awb_number"/>
                <field name="estimated_delivery" widget="remaining_days"/>
                <field name="status" widget="badge" 
                       decoration-info="status == 'label_created'"
                       decoration-warning="status in ('picked_up', 'in_transit', 'out_for_delivery')" 
                       decoration-success="status == 'delivered'" 
                       decoration-danger="status == 'delivery_failed'"/>
                <field name="is_high_value" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_logistics_form" model="ir.ui.view">
        <field name="name">gold.logistics.form</field>
        <field name="model">gold.logistics</field>
        <field name="arch" type="xml">
            <form string="Shipment">
                <header>
                    <button name="action_picked_up" string="Record Pickup" type="object" class="btn-primary" invisible="status != 'pickup_scheduled'"/>
                    <button name="action_in_transit" string="Mark In Transit" type="object" class="btn-info" invisible="status != 'picked_up'"/>
                    <button name="action_out_for_delivery" string="Out for Delivery" type="object" class="btn-warning" invisible="status != 'in_transit'"/>
                    <button name="action_delivered" string="Delivered" type="object" class="btn-success" invisible="status != 'out_for_delivery'"/>
                    <button name="action_failed" string="Mark Failed" type="object" class="btn-danger" invisible="status in ['delivered', 'delivery_failed']"/>
                    <field name="status" widget="statusbar" statusbar_visible="label_created,picked_up,in_transit,delivered"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Delivered" bg_color="text-bg-success" invisible="status != 'delivered'"/>
                    <widget name="web_ribbon" title="Failed" bg_color="text-bg-danger" invisible="status != 'delivery_failed'"/>
                    <widget name="web_ribbon" title="In Transit" bg_color="text-bg-info" invisible="status != 'in_transit'"/>

                    <div class="oe_title">
                        <label for="name" string="Tracking # / AWB"/>
                        <h1><field name="name" readonly="1"/></h1>
                        <label for="awb_number" string="Carrier AWB"/>
                        <h2><field name="awb_number" placeholder="Enter Carrier AWB Number"/></h2>
                    </div>
                    <group>
                        <group string="Carrier Service">
                            <field name="order_id" options="{'no_create': True}"/>
                            <field name="carrier"/>
                            <field name="aggregator"/>
                            <field name="delivery_type"/>
                        </group>
                        <group string="Timeline">
                            <field name="dispatch_date"/>
                            <field name="estimated_delivery"/>
                            <field name="actual_delivery" readonly="1"/>
                            <field name="pickup_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Logistics Details" name="details">
                            <group>
                                <group string="Weight &amp; Dimensions">
                                    <field name="shipping_weight"/>
                                    <field name="shipping_volume"/>
                                    <field name="shipping_rate" widget="monetary"/>
                                </group>
                                <group string="Routing Info">
                                    <field name="shipping_zone"/>
                                    <field name="is_remote_area" widget="boolean_toggle"/>
                                    <field name="remote_surcharge" invisible="is_remote_area == False"/>
                                </group>
                            </group>
                        </page>
                        <page string="Security &amp; High Value" name="security">
                            <group>
                                <group string="Shipment Protection">
                                    <field name="is_high_value" widget="boolean_toggle"/>
                                    <field name="insurance_required" widget="boolean_toggle"/>
                                    <field name="insurance_amount" invisible="insurance_required == False"/>
                                </group>
                                <group string="Features">
                                    <field name="gps_tracking" widget="boolean_toggle"/>
                                    <field name="tamper_proof" widget="boolean_toggle"/>
                                </group>
                            </group>
                        </page>
                        <page string="Delivery Spec &amp; POD" name="delivery">
                            <group>
                                <group string="Address Information">
                                    <field name="from_address"/>
                                    <field name="to_address"/>
                                    <field name="pincode"/>
                                </group>
                                <group string="Instructions &amp; Proof">
                                    <field name="delivery_instructions"/>
                                    <field name="signature_required"/>
                                    <field name="pod_image" widget="image"/>
                                </group>
                            </group>
                        </page>
                        <page string="Warehouse Documentation" name="warehouse">
                            <group>
                                <group string="Status">
                                    <field name="quality_check_done" widget="boolean_toggle"/>
                                    <field name="is_gift_wrapped" widget="boolean_toggle"/>
                                </group>
                                <group string="Labels">
                                    <field name="has_jewelry_cert"/>
                                    <field name="has_warranty_card"/>
                                    <field name="has_care_instructions"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_gold_logistics_kanban" model="ir.ui.view">
        <field name="name">gold.logistics.kanban</field>
        <field name="model">gold.logistics</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1" create="0">
                <field name="name"/>
                <field name="carrier"/>
                <field name="status"/>
                <field name="awb_number"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <span class="float-end"><field name="carrier" widget="label_selection" options="{'classes': {'bluedart': 'info', 'fedex': 'primary'}}"/></span>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="text-muted fa fa-truck"> <field name="awb_number"/></div>
                                <div class="mt-1">
                                    <field name="status" widget="badge" decoration-success="status == 'delivered'" decoration-info="status == 'in_transit'" decoration-danger="status == 'delivery_failed'"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_gold_logistics_graph" model="ir.ui.view">
        <field name="name">gold.logistics.graph</field>
        <field name="model">gold.logistics</field>
        <field name="arch" type="xml">
            <graph string="Logistics Analysis" sample="1">
                <field name="carrier"/>
                <field name="status"/>
            </graph>
        </field>
    </record>

    <record id="view_gold_logistics_calendar" model="ir.ui.view">
        <field name="name">gold.logistics.calendar</field>
        <field name="model">gold.logistics</field>
        <field name="arch" type="xml">
            <calendar string="Shipments" date_start="dispatch_date" date_stop="estimated_delivery" color="carrier" mode="month" create="0">
                <field name="name"/>
                <field name="carrier"/>
                <field name="status"/>
            </calendar>
        </field>
    </record>

    <record id="view_gold_logistics_search" model="ir.ui.view">
        <field name="name">gold.logistics.search</field>
        <field name="model">gold.logistics</field>
        <field name="arch" type="xml">
            <search string="Search Shipments">
                <field name="name" string="Tracking/AWB/Order" filter_domain="['|', '|', ('name', 'ilike', self), ('awb_number', 'ilike', self), ('order_id', 'ilike', self)]"/>
                <field name="awb_number"/>
                <field name="carrier"/>
                <field name="status"/>
                <separator/>
                <filter name="in_transit" string="In Transit" domain="[('status', 'in', ('picked_up', 'in_transit', 'out_for_delivery'))]"/>
                <filter name="delivered" string="Delivered" domain="[('status', '=', 'delivered')]"/>
                <filter name="issue" string="Issues/Failed" domain="[('status', '=', 'delivery_failed')]"/>
                <separator/>
                <filter name="express" string="Express Delivery" domain="[('delivery_type', '=', 'express')]"/>
                <filter name="high_value" string="High Value" domain="[('is_high_value', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_carrier" string="Carrier" context="{'group_by': 'carrier'}"/>
                    <filter name="group_by_status" string="Tracking Status" context="{'group_by': 'status'}"/>
                    <filter name="group_by_order" string="Order" context="{'group_by': 'order_id'}"/>
                    <filter name="group_by_month" string="Dispatch Month" context="{'group_by': 'dispatch_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gold_logistics" model="ir.actions.act_window">
        <field name="name">Logistics &amp; Tracking</field>
        <field name="res_model">gold.logistics</field>
        <field name="view_mode">tree,kanban,calendar,graph,form</field>
        <field name="context">{'search_default_in_transit': 1}</field>
    </record>

    <menuitem id="menu_gold_log_root" name="Logistics" parent="menu_sales_management_root" sequence="70"/>
    <menuitem id="menu_gold_logistics" name="All Shipments" parent="menu_gold_log_root" action="action_gold_logistics" sequence="10"/>
</odoo>
