              name="Jewelry Items" 
              parent="menu_gold_inventory_root" 
              action="action_gold_inventory" 
              sequence="10"/>

    <menuitem id="menu_gold_category" 
              name="Categories" 
              parent="menu_gold_inventory_root" 
