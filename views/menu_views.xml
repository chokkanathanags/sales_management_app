              name="Gold Sale Management" 
              sequence="10" 
              web_icon="base,static/description/icon.png"/>

    <!-- Inventory Section -->
    <menuitem id="menu_gold_inventory_root" 
              name="Inventory" 
              parent="menu_sales_management_root" 
              sequence="10"/>
              
