<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gold_customer_tree" model="ir.ui.view">
        <field name="name">gold.customer.tree</field>
        <field name="model">gold.customer</field>
        <field name="arch" type="xml">
            <tree string="Customers" decoration-info="segment == 'regular'" decoration-warning="segment == 'gold'" decoration-success="segment == 'platinum'" sample="1">
                <field name="name"/>
                <field name="mobile" widget="phone"/>
                <field name="email" widget="email"/>
                <field name="segment" widget="badge" decoration-info="segment == 'regular'" decoration-warning="segment == 'gold'" decoration-success="segment == 'platinum'"/>
                <field name="total_purchase_value" sum="Total Lifetime Value" widget="monetary" options="{'currency_field': 'currency_name'}"/>
                <field name="loyalty_points" optional="show"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-info="state == 'inactive'" decoration-danger="state == 'blacklisted'"/>
            </tree>
        </field>
    </record>
    <record id="view_gold_customer_form" model="ir.ui.view">
        <field name="name">gold.customer.form</field>
        <field name="model">gold.customer</field>
        <field name="arch" type="xml">
            <form string="Customer">
                <header>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary" invisible="state != 'prospect'"/>
                    <button name="action_make_vip" string="Mark as VIP" type="object" class="btn-warning" invisible="state != 'active'"/>
                    <button name="action_deactivate" string="Deactivate" type="object" invisible="state not in ['active', 'vip']"/>
                    <button name="action_blacklist" string="Blacklist" type="object" class="btn-danger" invisible="state == 'blacklisted'"/>
                    <button name="action_update_metrics" string="Refresh Metrics" type="object" icon="fa-refresh" class="btn-info" help="Recalculate LTV, Order Count and Loyalty Points"/>
                    <field name="state" widget="statusbar" statusbar_visible="prospect,active,vip"/>
                </header>
                <sheet>

                    <field name="image" widget="image" class="oe_avatar" options='{"preview_image": "image"}'/>
                    <div class="oe_title">
                        <label for="name" string="Customer Name"/>
                        <h1><field name="name" placeholder="e.g. John Doe"/></h1>
                        <label for="unique_customer_id" string="Customer Global ID"/>
                        <h2><field name="unique_customer_id" placeholder="Gold-ID-XXXXX"/></h2>
                    </div>
                    <group>
                        <group string="Primary Contact">
                            <field name="mobile" widget="phone" placeholder="+91 XXXX-XXXXXX"/>
                            <field name="email" widget="email" placeholder="customer@email.com"/>
                            <field name="partner_id" placeholder="Link to system partner"/>
                        </group>
                        <group string="Segmentation">
                            <field name="segment" widget="radio" options="{'horizontal': true}"/>
                            <field name="preferred_store"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Profile &amp; Personal" name="profile">
                            <group>
                                <group string="Demographics">
                                    <field name="first_name"/>
                                    <field name="last_name"/>
                                    <field name="gender"/>
                                    <field name="date_of_birth"/>
                                    <field name="anniversary_date"/>
                                </group>
                                <group string="KYC &amp; Identity">
                                    <field name="pan_number" placeholder="Enter PAN"/>
                                    <field name="gst_number" placeholder="Enter GST if corporate"/>
                                    <field name="aadhaar_number"/>
                                </group>
                            </group>
                        </page>
                        <page string="Transactions &amp; Analytics" name="analytics">
                            <group>
                                <group string="Loyalty Program">
                                    <field name="loyalty_points" decoration-bf="1" decoration-info="1"/>
                                    <field name="loyalty_points_lifetime"/>
                                </group>
                                <group string="Purchase Summary">
                                    <field name="total_purchase_value" widget="monetary" options="{'currency_field': 'currency_name'}"/>
                                    <field name="last_purchase_date"/>
                                    <field name="avg_order_value" widget="monetary"/>
                                    <field name="currency_name" invisible="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Communication &amp; Saved Loc" name="logistics">
                            <group>
                                <group string="Delivery Addresses">
                                    <field name="shipping_address" placeholder="Main shipping address..."/>
                                    <field name="billing_address" placeholder="Billing address if different..."/>
                                </group>
                                <group string="Preferences">
                                    <field name="comm_email"/>
                                    <field name="comm_sms"/>
                                    <field name="comm_whatsapp"/>
                                    <field name="language"/>
                                </group>
                            </group>
                        </page>
                        <page string="Internal Notes" name="description">
                            <field name="description" placeholder="Internal relationship notes..."/>
                        </page>
                        <page string="Internal Log" name="notes">
                            <field name="description" placeholder="Confidential customer notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_gold_customer_kanban" model="ir.ui.view">
        <field name="name">gold.customer.kanban</field>
        <field name="model">gold.customer</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="mobile"/>
                <field name="email"/>
                <field name="segment"/>
                <field name="image"/>
                <field name="total_purchase_value"/>
                <field name="currency_name"/>
                <field name="loyalty_points"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_image">
                                <field name="image" widget="image" class="oe_avatar" options="{'zoom': true, 'background': true, 'prevent_create': true}"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div class="o_kanban_record_subtitle">
                                    <field name="mobile"/>
                                </div>
                                <div>
                                    <span class="badge badge-pill badge-primary"><field name="segment"/></span>
                                </div>
                                <div class="mt-2 text-primary font-weight-bold">
                                    <field name="total_purchase_value" widget="monetary" options="{'currency_field': 'currency_name'}"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="loyalty_points" widget="integer"/> Points
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="state" widget="label_selection" options="{'classes': {'prospect': 'info', 'active': 'success', 'vip': 'warning', 'blacklisted': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_gold_customer_calendar" model="ir.ui.view">
        <field name="name">gold.customer.calendar</field>
        <field name="model">gold.customer</field>
        <field name="arch" type="xml">
            <calendar string="Customers" date_start="registration_date" color="segment" mode="month">
                <field name="name"/>
                <field name="segment"/>
            </calendar>
        </field>
    </record>

    <record id="view_gold_customer_search" model="ir.ui.view">
        <field name="name">gold.customer.search</field>
        <field name="model">gold.customer</field>
        <field name="arch" type="xml">
            <search string="Search Customers">
                <field name="name" filter_domain="['|', '|', ('name', 'ilike', self), ('mobile', 'ilike', self), ('email', 'ilike', self)]" string="Name/Mobile/Email"/>
                <field name="unique_customer_id"/>
                <field name="segment"/>
                <field name="state"/>
                
                <separator/>
                <filter name="active_only" string="Active Customers" domain="[('state', '=', 'active')]"/>
                <filter name="vip_only" string="VIP Customers" domain="[('state', '=', 'vip')]"/>
                <filter name="high_value" string="High Value (>50k)" domain="[('total_purchase_value', '>', 50000)]"/>
                
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_segment" string="Segment/Tier" context="{'group_by': 'segment'}"/>
                    <filter name="group_by_store" string="Preferred Store" context="{'group_by': 'preferred_store'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gold_customer" model="ir.actions.act_window">
        <field name="name">Gold Customers</field>
        <field name="res_model">gold.customer</field>
        <field name="view_mode">tree,kanban,calendar,form</field>
        <field name="limit">20</field>
        <field name="context">{'search_default_active_custs': 1}</field>
    </record>

    <menuitem id="menu_gold_customer_root" name="Customers" parent="menu_sales_management_root" sequence="50"/>
    <menuitem id="menu_gold_customer" name="All Customers" parent="menu_gold_customer_root" action="action_gold_customer" sequence="10"/>
</odoo>
