<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gold_rate_tree" model="ir.ui.view">
        <field name="name">gold.rate.tree</field>
        <field name="model">gold.rate</field>
        <field name="arch" type="xml">
            <tree string="Gold Rates" decoration-muted="not active" decoration-bf="active">
                <field name="effective_date"/>
                <field name="name"/>
                <field name="metal_type"/>
                <field name="karat"/>
                <field name="price_per_gram" string="Rate/g" decoration-bf="1"/>
                <field name="price_per_10g" string="Rate/10g"/>
                <field name="rate_source" widget="badge"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_rate_form" model="ir.ui.view">
        <field name="name">gold.rate.form</field>
        <field name="model">gold.rate</field>
        <field name="arch" type="xml">
            <form string="Gold Rate" class="tab-pricing-accent">
                <sheet>
                    <notebook>
                        <page string="Rate Details" name="details">
                            <group>
                                <group string="Basic Info">
                                    <field name="name" placeholder="e.g. Daily Market Rate - 22K (916)"/>
                                    <field name="code" placeholder="e.g. GOLD-22K-DAILY"/>
                                    <field name="metal_type" placeholder="e.g. Gold, Silver, Platinum"/>
                                    <field name="karat" placeholder="e.g. 22K, 24K, 18K"/>
                                    <field name="purity_factor" placeholder="e.g. 0.916"/>
                                </group>
                                <group string="Current Price">
                                    <field name="price_per_gram" placeholder="e.g. 6250.00"/>
                                    <field name="price_per_10g" placeholder="e.g. 62500.00"/>
                                    <field name="price_per_tola" placeholder="e.g. 72900.00"/>
                                    <field name="rate_source" placeholder="e.g. Dubai Gold Market, Local Bullion"/>
                                    <field name="region" placeholder="e.g. Bangalore, KA"/>
                                    <field name="active"/>
                                </group>
                            </group>
                        </page>
                        <page string="Price Components" name="components">
                            <group>
                                <group string="Charges &amp; Wastage">
                                    <field name="making_charge_fixed" placeholder="e.g. 150.00"/>
                                    <field name="making_charge_pct" placeholder="e.g. 12.0 (%)"/>
                                    <field name="wastage_pct" placeholder="e.g. 3.5 (%)"/>
                                </group>
                                <group string="Taxation (%)">
                                    <field name="gst_gold" placeholder="e.g. 3.0 (%)"/>
                                    <field name="gst_making" placeholder="e.g. 5.0 (%)"/>
                                    <field name="gst_diamond" placeholder="e.g. 18.0 (%)"/>
                                </group>
                            </group>
                        </page>
                        <page string="Validity &amp; Notes" name="validity">
                            <group>
                                <group string="Dates">
                                    <field name="effective_date"/>
                                    <field name="expiry_date"/>
                                </group>
                                <group string="Pricelist">
                                    <field name="pricelist_id"/>
                                </group>
                            </group>
                            <field name="description" placeholder="Add specific details about the source of this rate..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gold_rate_search" model="ir.ui.view">
        <field name="name">gold.rate.search</field>
        <field name="model">gold.rate</field>
        <field name="arch" type="xml">
            <search string="Search Rates">
                <field name="name"/>
                <field name="karat"/>
                <field name="metal_type"/>
                <field name="rate_source"/>
                <filter name="active_only" string="Active" domain="[('active', '=', True)]"/>
                <filter name="gold" string="Gold" domain="[('metal_type', '=', 'gold')]"/>
                <filter name="silver" string="Silver" domain="[('metal_type', '=', 'silver')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_metal" string="Metal Type" context="{'group_by': 'metal_type'}"/>
                    <filter name="group_by_karat" string="Karat" context="{'group_by': 'karat'}"/>
                    <filter name="group_by_source" string="Rate Source" context="{'group_by': 'rate_source'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_gold_pricelist_tree" model="ir.ui.view">
        <field name="name">gold.pricelist.tree</field>
        <field name="model">gold.pricelist</field>
        <field name="arch" type="xml">
            <tree string="Price Lists">
                <field name="name"/>
                <field name="code"/>
                <field name="channel"/>
                <field name="customer_segment"/>
                <field name="priority"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_pricelist_form" model="ir.ui.view">
        <field name="name">gold.pricelist.form</field>
        <field name="model">gold.pricelist</field>
        <field name="arch" type="xml">
            <form string="Price List">
                <sheet>
                    <group>
                        <group string="Details">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="channel"/>
                            <field name="priority"/>
                            <field name="active"/>
                        </group>
                        <group string="Applicability">
                            <field name="customer_segment" placeholder="e.g. VIP, Wholesale, Retail"/>
                            <field name="region" placeholder="e.g. South India, GCC"/>
                            <field name="start_date" placeholder="Effective From"/>
                            <field name="end_date" placeholder="Valid Until"/>
                        </group>
                    </group>
                    <field name="rate_ids">
                        <tree>
                            <field name="name"/>
                            <field name="metal_type"/>
                            <field name="karat"/>
                            <field name="price_per_gram"/>
                            <field name="effective_date"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gold_pricelist_search" model="ir.ui.view">
        <field name="name">gold.pricelist.search</field>
        <field name="model">gold.pricelist</field>
        <field name="arch" type="xml">
            <search string="Search Price Lists">
                <field name="name"/>
                <field name="channel"/>
                <field name="customer_segment"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_channel" string="Channel" context="{'group_by': 'channel'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_gold_price_history_tree" model="ir.ui.view">
        <field name="name">gold.price.history.tree</field>
        <field name="model">gold.price.history</field>
        <field name="arch" type="xml">
            <tree string="Price History">
                <field name="rate_id"/>
                <field name="old_price"/>
                <field name="new_price"/>
                <field name="change_date"/>
                <field name="changed_by"/>
                <field name="approval_state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_gold_price_history_search" model="ir.ui.view">
        <field name="name">gold.price.history.search</field>
        <field name="model">gold.price.history</field>
        <field name="arch" type="xml">
            <search string="Search Price History">
                <field name="rate_id"/>
                <field name="changed_by"/>
                <field name="approval_state"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_rate" string="Rate" context="{'group_by': 'rate_id'}"/>
                    <filter name="group_by_approval" string="Approval State" context="{'group_by': 'approval_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gold_rate" model="ir.actions.act_window">
        <field name="name">Gold Pricing</field>
        <field name="res_model">gold.rate</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_gold_pricelist" model="ir.actions.act_window">
        <field name="name">Price Lists</field>
        <field name="res_model">gold.pricelist</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_gold_price_history" model="ir.actions.act_window">
        <field name="name">Price History</field>
        <field name="res_model">gold.price.history</field>
        <field name="view_mode">tree</field>
    </record>

</odoo>
