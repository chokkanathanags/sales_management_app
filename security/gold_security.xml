<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Application Category -->
        <record id="module_category_sales_management_app" model="ir.module.category">
            <field name="name">Gold ERP</field>
            <field name="description">Helps you manage your gold retail operations.</field>
            <field name="sequence">10</field>
        </record>

        <!-- Roles / Groups -->
        <record id="group_gold_salesperson" model="res.groups">
            <field name="name">Salesperson</field>
            <field name="category_id" ref="module_category_sales_management_app"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can view inventory and customer data, and create orders.</field>
        </record>

        <record id="group_gold_inventory_manager" model="res.groups">
            <field name="name">Inventory Manager</field>
            <field name="category_id" ref="module_category_sales_management_app"/>
            <field name="implied_ids" eval="[(4, ref('group_gold_salesperson'))]"/>
            <field name="comment">Can manage all inventory items, stock transfers, and quality checks.</field>
        </record>

        <record id="group_gold_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_sales_management_app"/>
            <field name="implied_ids" eval="[(4, ref('group_gold_inventory_manager'))]"/>
            <field name="comment">Has full access to pricing rates, loyalty programs, returns approval, and financial reports.</field>
        </record>
    </data>
</odoo>
